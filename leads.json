      "parameters": {
        "jsCode": "// 1. Use n8n's built-in helper to safely extract the binary data as a text string\nconst rawText = await this.helpers.getBinaryDataBuffer(0, 'data').then(buf => buf.toString('utf-8'));\n\n// 2. Parse that clean string into a JSON array\nconst parsedJson = JSON.parse(rawText);\n\n// 3. Return it as a JSON key named 'agents' for your Split Out node\nreturn {\n  json: {\n    agents: parsedJson\n  }\n};"
