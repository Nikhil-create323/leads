    {
      "parameters": {
        "jsCode": "// Extract and trim lead data\nconst rawEmail = ($input.first().json.email || '').toString().trim();\nconst rawRequirements = ($input.first().json.requirements || '').toString().trim();\nconst rawCompany = ($input.first().json.company || '').toString().trim();\nconst rawMobile = ($input.first().json.mobile || '').toString().trim();\nconst rawSource = ($input.first().json.source || '').toString().trim();\n\nconst errors = [];\n\n// 1. Email validation (Basic regex check)\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (!emailRegex.test(rawEmail)) {\n  errors.push(\"Invalid email format.\");\n}\n\n// 2. Requirements length check (< 600 characters after trimming)\nif (rawRequirements.length >= 600) {\n  errors.push(\"Requirements must be less than 600 characters.\");\n}\n\n// 3. Company name length check (< 50 characters)\nif (rawCompany.length >= 50) {\n  errors.push(\"Company name must be less than 50 characters.\");\n}\n\n// 4. Mobile number validation (Exactly 10 digits)\n// This strips away any accidental spaces/dashes first to just check the digits\nconst cleanMobile = rawMobile.replace(/\\D/g, ''); \nif (cleanMobile.length !== 10) {\n  errors.push(\"Mobile number must be a valid 10-digit number.\");\n}\n\n// 5. Source length check (< 30 characters)\nif (rawSource.length >= 30) {\n  errors.push(\"Source must be less than 30 characters.\");\n}\n\n// Return appropriate JSON based on validation results\nif (errors.length > 0) {\n  return {\n    \"status\": \"error\",\n    \"errors\": errors\n  };\n}\n\nreturn {\n  \"lead\": {\n    \"email\": rawEmail,\n    \"company\": rawCompany,\n    \"requirements\": rawRequirements,\n    \"mobile\": cleanMobile, // returns clean 10-digit string\n    \"source\": rawSource\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2448,
        -1408
      ],
